{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Universal-Data-Interchange-Format/udif/spec/schema/udif.schema.json",
  "title": "Universal Data Interchange Format (UDIF) 2.0",
  "description": "A modular, ethical, and AI-ready data format for sovereign, portable, and context-rich user data. Invented by Angela Benton.",
  "type": "object",
  "required": ["udif", "meta", "platform", "data_event"],
  "properties": {
    "udif": {
      "type": "string",
      "description": "UDIF specification version",
      "const": "2.0"
    },
    "meta": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "generator": { "type": "string" },
        "session_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "user_id": { "type": "string" },
        "consent_granted": { "type": "boolean" },
        "consent_type": { 
          "type": "string", 
          "enum": ["explicit", "contextual", "implied"] 
        },
        "data_type": { "type": "string" }
      },
      "required": ["source", "session_id", "timestamp", "consent_granted"]
    },
    "identity": {
      "type": "object",
      "properties": {
        "alias": { "type": "string" },
        "public_key": { "type": "string" },
        "public_key_format": {
          "type": "string",
          "enum": ["jwk", "pem", "base64"],
          "description": "Format of the public_key field. JWK (RFC 7517) is recommended for interoperability."
        },
        "persona_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "archetype": { "type": "string" },
        "language": { 
          "type": "string",
          "description": "BCP 47 language tag (e.g. en-US)"
        },
        "timezone": { "type": "string" }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" },
            "geo_label": { "type": "string" }
          },
          "required": ["latitude", "longitude"]
        },
        "device": {
          "type": "object",
          "properties": {
            "type": { "type": "string" },
            "os": { "type": "string" }
          }
        },
        "emotional_state": {
          "type": "array",
          "items": { "type": "string" }
        },
        "presence_level": { 
          "type": "string", 
          "enum": ["low", "medium", "high"] 
        },
        "energy_score": { 
          "type": "integer", 
          "minimum": 1, 
          "maximum": 10 
        }
      }
    },
    "platform": {
      "type": "object",
      "properties": {
        "name": { 
          "type": "string",
          "description": "Platform name. Use the platform's official product name as it appears in their documentation (e.g. 'OpenAI', 'Anthropic', 'Google', 'Mistral', 'Ollama'). Any string value is valid."
        },
        "data_format": { 
          "type": "string", 
          "enum": ["json", "html", "markdown", "zip", "csv", "proprietary"] 
        },
        "source_type": { 
          "type": "string", 
          "enum": ["chat_log", "file", "search", "audio", "image", "video", "code", "multimodal"] 
        },
        "raw_schema_reference": { "type": "string" },
        "export_date": { "type": "string", "format": "date-time" },
        "session_reference_id": { "type": "string" }
      },
      "required": ["name", "data_format", "source_type", "export_date"]
    },
    "data_event": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "service": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "content_title": { "type": "string" },
        "duration": { "type": "integer" },
        "value_perceived": { 
          "type": "integer", 
          "minimum": 1, 
          "maximum": 10 
        },
        "is_shareable": { "type": "boolean" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { 
                "type": "string", 
                "enum": ["user", "assistant", "system", "tool", "developer"]
              },
              "content": {
                "oneOf": [
                  { 
                    "type": "string",
                    "description": "Plain text message content"
                  },
                  {
                    "type": "array",
                    "description": "Structured content blocks for multimodal or tool-use messages",
                    "items": {
                      "type": "object",
                      "required": ["type"],
                      "properties": {
                        "type": {
                          "type": "string",
                          "enum": ["text", "image", "file", "tool_call", "tool_result", "code_execution"]
                        },
                        "text": { 
                          "type": "string",
                          "description": "Text content (for type: text)"
                        },
                        "source": { 
                          "type": "string",
                          "description": "Content origin: 'generated', 'uploaded', 'url' (for type: image, file)"
                        },
                        "media_type": { 
                          "type": "string",
                          "description": "MIME type (for type: image, file)"
                        },
                        "url": { 
                          "type": "string",
                          "description": "URL or path to external content (for type: image, file)"
                        },
                        "data": { 
                          "type": "string",
                          "description": "Base64-encoded inline content (for type: image, file)"
                        },
                        "description": { 
                          "type": "string",
                          "description": "Human-readable description (for type: image)"
                        },
                        "filename": { 
                          "type": "string",
                          "description": "Original filename (for type: file)"
                        },
                        "tool_name": { 
                          "type": "string",
                          "description": "Name of the tool invoked (for type: tool_call)"
                        },
                        "tool_input": { 
                          "type": "object",
                          "description": "Parameters passed to the tool (for type: tool_call)"
                        },
                        "tool_call_id": { 
                          "type": "string",
                          "description": "Correlation ID (for type: tool_call, tool_result)"
                        },
                        "is_error": { 
                          "type": "boolean",
                          "description": "Whether the tool result is an error (for type: tool_result)"
                        },
                        "code": { 
                          "type": "string",
                          "description": "Source code (for type: code_execution)"
                        },
                        "language": { 
                          "type": "string",
                          "description": "Programming language (for type: code_execution)"
                        },
                        "output": { 
                          "type": "string",
                          "description": "Execution output (for type: code_execution)"
                        },
                        "exit_code": { 
                          "type": "integer",
                          "description": "Process exit code (for type: code_execution)"
                        }
                      }
                    }
                  }
                ]
              },
              "timestamp": { "type": "string", "format": "date-time" },
              "name": {
                "type": "string",
                "description": "Identifier for the message author in multi-agent scenarios"
              },
              "model": {
                "type": "string",
                "description": "Model that generated this message (e.g. 'gpt-4o', 'claude-sonnet-4-5-20250929')"
              },
              "tool_call_id": {
                "type": "string",
                "description": "Correlation ID linking a tool result to the tool_call that triggered it"
              },
              "attachments": {
                "type": "array",
                "description": "Files associated with this message",
                "items": {
                  "type": "object",
                  "required": ["filename"],
                  "properties": {
                    "filename": { "type": "string" },
                    "media_type": { "type": "string" },
                    "size_bytes": { "type": "integer" },
                    "url": { "type": "string" }
                  }
                }
              }
            },
            "required": ["role", "content", "timestamp"]
          }
        },
        "shared_links": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["type", "service"]
    },
    "values": {
      "type": "object",
      "properties": {
        "data_use_permissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sharing_boundaries": {
          "type": "array",
          "items": { "type": "string" }
        },
        "preferred_exchanges": {
          "type": "array",
          "items": { "type": "string" }
        },
        "core_values": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "frequency": {
      "type": "object",
      "properties": {
        "intended_impact": { "type": "string" },
        "creative_source": { "type": "string" },
        "self_expression_level": { 
          "type": "string", 
          "enum": ["low", "medium", "high"] 
        },
        "authenticity_score": { 
          "type": "integer", 
          "minimum": 1, 
          "maximum": 10 
        },
        "energetic_signature": { "type": "string" }
      }
    },
    "provenance": {
      "type": "object",
      "description": "Cryptographic metadata establishing origin, authenticity, and integrity",
      "required": ["created_at", "source"],
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of file creation"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last update"
        },
        "source": {
          "type": "string",
          "description": "Platform or system the data originated from"
        },
        "hash": {
          "type": "string",
          "description": "SHA-256 hash of the data_event object for integrity verification"
        },
        "signature": {
          "type": "string",
          "description": "Optional cryptographic signature proving authorship"
        },
        "chain": {
          "type": "array",
          "description": "Auditable history of every platform this data has moved through",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string" },
              "exported_at": {
                "type": "string",
                "format": "date-time"
              },
              "hash": { 
                "type": "string",
                "description": "Hash of data at point of export, enabling tamper detection"
              }
            }
          }
        }
      }
    },
    "raw_payload": { "type": "object" },
    "raw_payload_ref": { "type": "string" }
  }
}
